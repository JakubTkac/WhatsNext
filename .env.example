# Optional Docker Compose overrides. `docker compose up` works without this file.
POSTGRES_USER=whatsnext
POSTGRES_PASSWORD=whatsnext_local_password
POSTGRES_DB=whatsnext

JWT_SECRET=replace-with-a-long-random-value-outside-local-development
JWT_EXPIRES_IN_SECONDS=86400
JWT_ISSUER=whatsnext-api
JWT_AUDIENCE=whatsnext-web
BCRYPT_ROUNDS=12

FRONTEND_PORT=3000
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:3000
SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api
